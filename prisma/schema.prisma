generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores     Store[]      @relation("UserStores")
  mrs        MR[]
  sales      Sale[]
  attendance Attendance[]
  stock      Stock[]
}

model MR {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String
  territory String?
  salary    Float?
  userId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User?        @relation(fields: [userId], references: [id])
  attendance Attendance[]
  sales      Sale[]

  // ✅ Junction relation
  mrStores MRStore[]
}

model Store {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  contact   String?
  userId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation("UserStores", fields: [userId], references: [id])

  // ✅ Junction relation
  mrStores MRStore[]

  stock Stock[]
  sales Sale[]
}

model MRStore {
  mrId       Int
  storeId    Int
  assignedAt DateTime @default(now())

  // ✅ Proper bidirectional relation
  mr    MR    @relation(fields: [mrId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@id([mrId, storeId])
  @@map("mr_stores")
}

model Sale {
  id          Int      @id @default(autoincrement())
  productName String
  quantity    Int
  price       Float
  totalAmount Float
  saleDate    DateTime @default(now())
  storeId     Int?
  mrId        Int?
  userId      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id])
  mr    MR?    @relation(fields: [mrId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

model Attendance {
  id           Int               @id @default(autoincrement())
  date         DateTime          @default(now()) // ✅ REMOVE @db.Date
  status       AttendanceStatus
  checkInTime  DateTime?         @default(now())
  checkOutTime DateTime?
  mrId         Int
  userId       Int?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  mr   MR   @relation(fields: [mrId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@unique([mrId, date])
}
model Stock {
  id          Int       @id @default(autoincrement())
  productName String
  quantity    Int
  minQuantity Int       @default(0)
  maxQuantity Int       @default(1000)
  price       Float
  expiryDate  DateTime?
  storeId     Int?
  userId      Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store Store? @relation(fields: [storeId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])
}
