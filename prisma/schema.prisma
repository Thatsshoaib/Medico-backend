generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int          @id @default(autoincrement())
  name       String
  email      String       @unique
  password   String
  role       String       @default("user")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  attendance Attendance[]
  mrs        MR[]
  stock      Stock[]
  stores     Store[]      @relation("UserStores")
  sales      Sale[]
  visits     Visit[]      // Add this relation
}

model MR {
  id         Int          @id @default(autoincrement())
  name       String
  createdAt  DateTime     @default(now())
  salary     Float?
  email      String       @unique
  phone      String
  territory  String?
  updatedAt  DateTime     @updatedAt
  userId     Int?
  attendance Attendance[]
  user       User?        @relation(fields: [userId], references: [id])
  mrStores   MRStore[]
  sales      Sale[]
  visits     Visit[]      // Add this relation

  @@index([userId], map: "MR_userId_fkey")
}

model Store {
  id        Int       @id @default(autoincrement())
  name      String
  contact   String?
  createdAt DateTime  @default(now())
  address   String?
  updatedAt DateTime  @updatedAt
  userId    Int?
  stock     Stock[]
  user      User?     @relation("UserStores", fields: [userId], references: [id])
  mrStores  MRStore[]
  sales     Sale[]
  visits    Visit[]   // Add this relation

  @@index([userId], map: "Store_userId_fkey")
}

model MRStore {
  mrId       Int
  storeId    Int
  assignedAt DateTime @default(now())
  mr         MR       @relation(fields: [mrId], references: [id])
  store      Store    @relation(fields: [storeId], references: [id])

  @@id([mrId, storeId])
  @@index([storeId], map: "mr_stores_storeId_fkey")
  @@map("mr_stores")
}

// ✅ NEW: Visit Model
model Visit {
  id          Int      @id @default(autoincrement())
  mrId        Int
  storeId     Int
  userId      Int?
  photoUrl    String?  @db.VarChar(500)
  notes       String?  @db.Text
  visitDate   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mr     MR     @relation(fields: [mrId], references: [id])
  store  Store  @relation(fields: [storeId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([mrId])
  @@index([storeId])
  @@index([userId])
  @@index([visitDate])
  @@map("visits")
}

model Sale {
  id          Int      @id @default(autoincrement())
  storeId     Int?
  mrId        Int?
  userId      Int?
  productName String
  quantity    Int
  price       Float
  saleDate    DateTime @default(now())
  createdAt   DateTime @default(now())
  // ✅ Remove photoUrl from Sale model (optional: keep for backward compatibility)
  // photoUrl    String?  @db.VarChar(500)  // COMMENT OUT OR REMOVE THIS LINE
  mr          MR?      @relation(fields: [mrId], references: [id])
  store       Store?   @relation(fields: [storeId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([mrId], map: "sale_mrId_fkey")
  @@index([storeId], map: "sale_storeId_fkey")
  @@index([userId], map: "sale_userId_fkey")
  @@map("sale")
}

model Attendance {
  id           Int              @id @default(autoincrement())
  date         DateTime         @default(now())
  status       AttendanceStatus
  mrId         Int
  checkInTime  DateTime?        @default(now())
  checkOutTime DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  userId       Int?
  photoUrl     String           @db.VarChar(500)
  mr           MR               @relation(fields: [mrId], references: [id])
  user         User?            @relation(fields: [userId], references: [id])

  @@unique([mrId, date])
  @@index([mrId])
  @@index([userId], map: "Attendance_userId_fkey")
}

model Stock {
  id          Int       @id @default(autoincrement())
  price       Float
  createdAt   DateTime  @default(now())
  expiryDate  DateTime?
  maxQuantity Int       @default(1000)
  minQuantity Int       @default(0)
  productName String
  quantity    Int
  storeId     Int?
  updatedAt   DateTime  @updatedAt
  userId      Int?
  store       Store?    @relation(fields: [storeId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@index([storeId], map: "Stock_storeId_fkey")
  @@index([userId], map: "Stock_userId_fkey")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}